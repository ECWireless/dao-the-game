{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daothegame.com/.well-known/dao-the-game/schemas/run-response.v1.json",
  "title": "DAO the Game Worker Run Response v1",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["specVersion", "ok", "handoff"],
      "properties": {
        "specVersion": {
          "const": "dao-the-game.run-response.v1"
        },
        "ok": {
          "const": true
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary", "contentType", "content"],
          "properties": {
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "contentType": {
              "type": "string",
              "enum": ["text/plain", "text/html", "application/json"]
            },
            "content": {
              "type": "string"
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["specVersion", "ok", "error"],
      "properties": {
        "specVersion": {
          "const": "dao-the-game.run-response.v1"
        },
        "ok": {
          "const": false
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
