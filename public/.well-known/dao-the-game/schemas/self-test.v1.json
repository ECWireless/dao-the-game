{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daothegame.com/.well-known/dao-the-game/schemas/self-test.v1.json",
  "title": "DAO the Game Worker Self-Test v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["specVersion", "ok", "worker", "checks"],
  "properties": {
    "specVersion": {
      "const": "dao-the-game.self-test.v1"
    },
    "ok": {
      "type": "boolean"
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "roleTag"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "roleTag": {
          "type": "string",
          "enum": ["ui-designer", "brand-designer", "frontend-engineer", "code-reviewer"]
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestReachable", "profileReachable", "runReachable"],
      "properties": {
        "manifestReachable": {
          "type": "boolean"
        },
        "profileReachable": {
          "type": "boolean"
        },
        "runReachable": {
          "type": "boolean"
        }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
